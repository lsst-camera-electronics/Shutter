<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4022.12">
  <DUT Name="IncomingMessage" Id="{410da9e1-5e84-4501-a293-cae3a2061246}">
    <Declaration><![CDATA[{attribute 'pack_mode' := '1'}
TYPE IncomingMessage :
STRUCT
	id: MessageID;   (* Used to identify new messages. *)
	version: LINT;   (* Matches serialVersionUID of the equivalent Java class. *)
END_STRUCT
END_TYPE
]]></Declaration>
  </DUT>
</TcPlcObject>